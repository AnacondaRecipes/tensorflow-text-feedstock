From b9e9358cd70096f4a12b83708db0621d682d8cef Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Wed, 21 Jan 2026 07:55:09 -0800
Subject: [PATCH] Add missing absl/strings/str_cat.h includes

When using system abseil instead of vendored abseil, some transitive
includes are not available. This adds explicit includes for str_cat.h
in tensorflow-text source files that use absl::StrCat or absl::StrAppend.
---
 tensorflow_text/core/kernels/BUILD                              | 1 +
 .../core/kernels/boise_offset_converter_kernel_template.h       | 1 +
 tensorflow_text/core/kernels/byte_splitter_kernel_template.h    | 1 +
 tensorflow_text/core/kernels/darts_clone_trie_builder.cc        | 1 +
 tensorflow_text/core/kernels/fast_bert_normalizer.h             | 1 +
 .../core/kernels/fast_bert_normalizer_model_builder.cc          | 1 +
 tensorflow_text/core/kernels/fast_bert_normalizer_test.cc       | 2 ++
 tensorflow_text/core/kernels/fast_wordpiece_tokenizer.cc        | 1 +
 tensorflow_text/core/kernels/fast_wordpiece_tokenizer_test.cc   | 2 ++
 tensorflow_text/core/kernels/phrase_tokenizer.cc                | 1 +
 .../core/kernels/phrase_tokenizer_model_builder.cc              | 1 +
 .../core/kernels/round_robin_trimmer_kernel_template.h          | 1 +
 .../core/kernels/sentence_fragmenter_v2_kernel_template.h       | 1 +
 .../core/kernels/whitespace_tokenizer_kernel_template.h         | 1 +
 14 files changed, 16 insertions(+)

diff --git a/tensorflow_text/core/kernels/boise_offset_converter_kernel_template.h b/tensorflow_text/core/kernels/boise_offset_converter_kernel_template.h
index 5926a23..f76c639 100644
--- a/tensorflow_text/core/kernels/boise_offset_converter_kernel_template.h
+++ b/tensorflow_text/core/kernels/boise_offset_converter_kernel_template.h
@@ -21,6 +21,7 @@
 #include <vector>
 
 #include "absl/status/status.h"
+#include "absl/strings/str_cat.h"
 #include "tensorflow/core/platform/tstring.h"
 #include "tensorflow/lite/kernels/shim/op_kernel.h"
 #include "tensorflow/lite/kernels/shim/shape.h"
diff --git a/tensorflow_text/core/kernels/byte_splitter_kernel_template.h b/tensorflow_text/core/kernels/byte_splitter_kernel_template.h

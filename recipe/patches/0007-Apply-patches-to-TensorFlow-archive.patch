From b2b88ae3385e209c2120a2611900860d8e9f8706 Mon Sep 17 00:00:00 2001
From: Eric Lundby <Eric.Lundby@gmail.com>
Date: Thu, 22 Jan 2026 11:12:40 -0700
Subject: [PATCH] Apply the patches to the TensorFlow repository during Bazel build.

Apply the patches created in 0005 and 0006 to the TensorFlow repository during Bazel build. 
---
 WORKSPACE | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/WORKSPACE b/WORKSPACE
index 0f454bd..43f80fa 100644
--- a/WORKSPACE
+++ b/WORKSPACE
@@ -71,7 +71,11 @@ http_archive(
     sha256 = "213edf03ac7c4e74d8eb2074216ae8c8ae4f325c6bc22efd16cfdeed2073bd66",
     strip_prefix = "tensorflow-2.20.0",
     patch_args = ["-p1"],
-    patches = ["//third_party/tensorflow:tensorflow.core.BUILD.patch"],
+    patches = [
+        "//third_party/tensorflow:tensorflow.core.BUILD.patch",
+        "//third_party/tensorflow:abseil_systemlib.patch",
+        "//third_party/tensorflow:protobuf_systemlib.patch",
+    ],
     urls = [
         "https://github.com/tensorflow/tensorflow/archive/refs/tags/v2.20.0.zip",
     ],
@@ -150,6 +154,28 @@ load("//third_party/tensorflow:tf_configure.bzl", "tf_configure")
 
 tf_configure()
 
+new_local_repository(
+    name = "pypi_tensorflow",
+    path = "__SYSTEM_TF_PATH__",
+    build_file_content = """
+cc_library(
+    name = "tf_header_lib",
+    hdrs = glob(["include/**/*"]),
+    strip_include_prefix = "include/",
+    visibility = ["//visibility:public"],
+)
+cc_library(
+    name = "libtensorflow_framework",
+    srcs = select({
+        "@bazel_tools//src/conditions:darwin": ["libtensorflow_framework.2.dylib"],
+        "//conditions:default": ["libtensorflow_framework.so.2"],
+    }),
+    visibility = ["//visibility:public"],
+)
+""",
+)
+
+
 load("@pypi//:requirements.bzl", "install_deps")
 
 install_deps()

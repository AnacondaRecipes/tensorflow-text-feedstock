From adf3232285b4438a5605730643ffb0552d5f002b Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Wed, 21 Jan 2026 09:11:48 -0800
Subject: [PATCH] link tesorflow from run_build

---
 oss_scripts/run_build.sh | 23 +++++++++++++++++++++++
 1 file changed, 23 insertions(+)

diff --git a/oss_scripts/run_build.sh b/oss_scripts/run_build.sh
index d680733..b4f8b94 100755
--- a/oss_scripts/run_build.sh
+++ b/oss_scripts/run_build.sh
@@ -81,6 +81,29 @@ if [[ -n "${PREFIX}" ]]; then
   echo "build --linkopt=-Wl,-rpath,${PREFIX}/lib" >> .bazelrc
 fi
 
+# Configure Bazel to find conda-provided TensorFlow headers and libraries
+if [[ -n "${PREFIX}" ]]; then
+  TF_INCLUDE_DIR="${PREFIX}/include/tensorflow"
+  TF_LIB_DIR="${PREFIX}/lib"
+  echo "" >> .bazelrc
+  echo "# Use conda-provided TensorFlow (2.19.1)" >> .bazelrc
+  # TensorFlow headers (framework, ops, etc.)
+  echo "build --cxxopt=-I${PREFIX}/include" >> .bazelrc
+  echo "build --host_cxxopt=-I${PREFIX}/include" >> .bazelrc
+  # Library search paths for TensorFlow libraries (via environment variable to avoid Bazel sandbox restrictions)
+  echo "build --action_env=LIBRARY_PATH=${TF_LIB_DIR}" >> .bazelrc
+  echo "build --action_env=LD_LIBRARY_PATH=${TF_LIB_DIR}" >> .bazelrc
+  echo "build --host_action_env=LIBRARY_PATH=${TF_LIB_DIR}" >> .bazelrc
+  echo "build --host_action_env=LD_LIBRARY_PATH=${TF_LIB_DIR}" >> .bazelrc
+  # TensorFlow library search paths
+  echo "build --linkopt=-L${TF_LIB_DIR}" >> .bazelrc
+  echo "build --host_linkopt=-L${TF_LIB_DIR}" >> .bazelrc
+  # Explicitly link against TensorFlow framework
+  echo "build --linkopt=-ltensorflow_framework" >> .bazelrc
+  # Runtime path for TensorFlow libraries
+  echo "build --linkopt=-Wl,-rpath,${TF_LIB_DIR}" >> .bazelrc
+fi
+
 # Build the pip package.
 # Execute only one action at a time instead of utilizing multiple parallel jobs
 bazel run ${BUILD_ARGS[@]} --enable_runfiles --jobs=1 //oss_scripts/pip_package:build_pip_package -- "$(realpath .)"
-- 

From 0bad88eb624a304a2d23b9e7adb2299d81b0150b Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Wed, 21 Jan 2026 05:05:17 -0800
Subject: [PATCH] Help bazel find correct SDKROOT before run command

---
 oss_scripts/run_build.sh | 22 ++++++++++++++++++++++
 1 file changed, 22 insertions(+)

diff --git a/oss_scripts/run_build.sh b/oss_scripts/run_build.sh
index 18985ce..822417b 100755
--- a/oss_scripts/run_build.sh
+++ b/oss_scripts/run_build.sh
@@ -13,6 +13,28 @@ fi
 # Run configure.
 source oss_scripts/configure.sh
 
+# Add conda-specific configuration after configure
+if [[ $osname == "darwin" ]] && [[ -n "${SDKROOT}" ]]; then
+  echo "" >> .bazelrc
+  echo "# Conda macOS sysroot configuration" >> .bazelrc
+  echo "build --action_env=SDKROOT=${SDKROOT}" >> .bazelrc
+  echo "build --action_env=DEVELOPER_DIR=${DEVELOPER_DIR}" >> .bazelrc
+  echo "build --copt=-isysroot${SDKROOT}" >> .bazelrc
+  echo "build --linkopt=-isysroot${SDKROOT}" >> .bazelrc
+  
+  # CRITICAL: Add host (tool) compilation flags
+  echo "build --host_copt=-isysroot${SDKROOT}" >> .bazelrc
+  echo "build --host_linkopt=-isysroot${SDKROOT}" >> .bazelrc
+  echo "build --host_action_env=SDKROOT=${SDKROOT}" >> .bazelrc
+  echo "build --host_action_env=DEVELOPER_DIR=${DEVELOPER_DIR}" >> .bazelrc
+  
+  echo "build --verbose_failures" >> .bazelrc
+fi
+
+# Show what we added for debugging
+echo "=== Last 10 lines of .bazelrc ==="
+tail -n 10 .bazelrc
+
 # Build the pip package.
 # Execute only one action at a time instead of utilizing multiple parallel jobs
 bazel run ${BUILD_ARGS[@]} --enable_runfiles --jobs=1 //oss_scripts/pip_package:build_pip_package -- "$(realpath .)"
-- 

From 16ffddf0a8c2c8198fd6183337511e0428ff2051 Mon Sep 17 00:00:00 2001
From: Eric Lundby <Eric.Lundby@gmail.com>
Date: Thu, 22 Jan 2026 11:13:42 -0700
Subject: [PATCH] Create abseil systemlib patch for TensorFlow

Creates abseil_systemlib.patch that gets applied to the TensorFlow source
during Bazel build. This patch:
- Updates system.absl.*.BUILD files to link against conda's libabseil
- Adds missing str_cat.h include to TF's status_macros.h
- Fixes linkopts for abseil libraries

Consolidated patches from tensorflow-feedstock. 
---
diff --git a/third_party/tensorflow/BUILD b/third_party/tensorflow/BUILD
--- a/third_party/tensorflow/BUILD
+++ b/third_party/tensorflow/BUILD
@@ -1,4 +1,4 @@
 # Needed for Bazel to treat this directory as a package
 
 # Export patch files for use by http_archive rules
-exports_files(["tflite_tensor_view_fix.patch"])
+exports_files(["tflite_tensor_view_fix.patch", "abseil_systemlib.patch"])
diff --git a/third_party/tensorflow/abseil_systemlib.patch b/third_party/tensorflow/abseil_systemlib.patch

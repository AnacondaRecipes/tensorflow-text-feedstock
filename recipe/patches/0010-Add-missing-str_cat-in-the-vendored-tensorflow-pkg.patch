From 98289297e240af7d19b9b6dfb4de8ece73655990 Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Thu, 22 Jan 2026 01:26:03 -0800
Subject: [PATCH] Add missing str_cat in the vendored tensorflow pkg

---
 WORKSPACE                                     |  4 +++
 third_party/tensorflow/BUILD                  |  2 ++
 .../tensorflow/fix-strcat-include.patch       | 25 +++++++++++++++++++
 3 files changed, 31 insertions(+)
 create mode 100644 third_party/tensorflow/fix-strcat-include.patch

diff --git a/WORKSPACE b/WORKSPACE
index 5bc8329..6c496f3 100644
--- a/WORKSPACE
+++ b/WORKSPACE
@@ -61,6 +61,10 @@ http_archive(
     urls = [
         "https://github.com/tensorflow/tensorflow/archive/v2.19.0.zip"
     ],
+    patches = [
+        "//third_party/tensorflow:fix-strcat-include.patch",
+    ],
+    patch_args = ["-p1"],
 )
 
 http_archive(
diff --git a/third_party/tensorflow/BUILD b/third_party/tensorflow/BUILD
index 2b0003e..1832873 100644
--- a/third_party/tensorflow/BUILD
+++ b/third_party/tensorflow/BUILD
@@ -1 +1,3 @@
 # Needed for Bazel to treat this directory as a package
+
+exports_files(["fix-strcat-include.patch"])
diff --git a/third_party/tensorflow/fix-strcat-include.patch b/third_party/tensorflow/fix-strcat-include.patch
new file mode 100644
index 0000000..1f41e01
--- /dev/null
+++ b/third_party/tensorflow/fix-strcat-include.patch
@@ -0,0 +1,25 @@
+From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
+From: Andrii Osipov <aosipov@anaconda.com>
+Date: Wed, 22 Jan 2026 00:00:00 -0800
+Subject: [PATCH] Add missing absl/strings/str_cat.h include
+
+This fixes the compilation error:
+  error: 'StrCat' is not a member of 'absl'
+when using newer abseil (20250127) with TensorFlow 2.19.0.
+
+---
+ tensorflow/lite/kernels/shim/tflite_tensor_view.cc | 1 +
+ 1 file changed, 1 insertion(+)
+
+diff --git a/tensorflow/lite/kernels/shim/tflite_tensor_view.cc b/tensorflow/lite/kernels/shim/tflite_tensor_view.cc
+index 0000000..1111111 100644
+--- a/tensorflow/lite/kernels/shim/tflite_tensor_view.cc
++++ b/tensorflow/lite/kernels/shim/tflite_tensor_view.cc
+@@ -19,6 +19,7 @@ limitations under the License.
+ #include "absl/status/status.h"
+ #include "absl/status/statusor.h"
+ #include "absl/types/variant.h"
++#include "absl/strings/str_cat.h"
+ #include "tensorflow/lite/core/c/common.h"
+ #include "tensorflow/lite/kernels/shim/tensor_view.h"
+ #include "tensorflow/lite/string_util.h"
-- 
2.39.3 (Apple Git-146)


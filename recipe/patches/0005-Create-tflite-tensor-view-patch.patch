From 24673eeb15864fb8558a24603c6751132a8de909 Mon Sep 17 00:00:00 2001
From: Eric Lundby <Eric.Lundby@gmail.com>
Date: Thu, 22 Jan 2026 11:11:57 -0700
Subject: [PATCH] Add missing strcat include

Similar to 0004-Add-str_cat-missing-includes.patch that fixes tensorflow-text source code, but this creates a 
patch file for the TensorFlow repository during Bazel build to apply the fix to the TensorFlow source code.

---
 third_party/tensorflow/BUILD                        |  3 +++
 third_party/tensorflow/tflite_tensor_view_fix.patch | 10 ++++++++++
 2 files changed, 13 insertions(+)
 create mode 100644 third_party/tensorflow/tflite_tensor_view_fix.patch

diff --git a/third_party/tensorflow/BUILD b/third_party/tensorflow/BUILD
--- a/third_party/tensorflow/BUILD
+++ b/third_party/tensorflow/BUILD
@@ -1 +1,4 @@
 # Needed for Bazel to treat this directory as a package
+
+# Export patch files for use by http_archive rules
+exports_files(["tflite_tensor_view_fix.patch"])
diff --git a/third_party/tensorflow/tflite_tensor_view_fix.patch b/third_party/tensorflow/tflite_tensor_view_fix.patch
new file mode 100644
--- /dev/null
+++ b/third_party/tensorflow/tflite_tensor_view_fix.patch
@@ -0,0 +1,10 @@
+--- a/tensorflow/lite/kernels/shim/tflite_tensor_view.cc
++++ b/tensorflow/lite/kernels/shim/tflite_tensor_view.cc
+@@ -18,6 +18,7 @@
+ 
+ #include "absl/status/status.h"
+ #include "absl/status/statusor.h"
++#include "absl/strings/str_cat.h"
+ #include "absl/types/variant.h"
+ #include "tensorflow/lite/core/c/common.h"
+ #include "tensorflow/lite/kernels/shim/tensor_view.h"

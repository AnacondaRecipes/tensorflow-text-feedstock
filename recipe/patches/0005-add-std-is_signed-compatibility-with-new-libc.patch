From 802ba3c375ac50fdff07f91d8c03255a6f10cc4f Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Wed, 21 Jan 2026 05:08:13 -0800
Subject: [PATCH] add std::is_signed compatibility with new libc++

---
 oss_scripts/run_build.sh | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/oss_scripts/run_build.sh b/oss_scripts/run_build.sh
index 822417b..14400af 100755
--- a/oss_scripts/run_build.sh
+++ b/oss_scripts/run_build.sh
@@ -27,14 +27,14 @@ if [[ $osname == "darwin" ]] && [[ -n "${SDKROOT}" ]]; then
   echo "build --host_linkopt=-isysroot${SDKROOT}" >> .bazelrc
   echo "build --host_action_env=SDKROOT=${SDKROOT}" >> .bazelrc
   echo "build --host_action_env=DEVELOPER_DIR=${DEVELOPER_DIR}" >> .bazelrc
+
+  # Compatibility: Allow TensorFlow's std::is_signed specializations with newer libc++
+  echo "build --copt=-Wno-invalid-specialization" >> .bazelrc
+  echo "build --host_copt=-Wno-invalid-specialization" >> .bazelrc
   
   echo "build --verbose_failures" >> .bazelrc
 fi
 
-# Show what we added for debugging
-echo "=== Last 10 lines of .bazelrc ==="
-tail -n 10 .bazelrc
-
 # Build the pip package.
 # Execute only one action at a time instead of utilizing multiple parallel jobs
 bazel run ${BUILD_ARGS[@]} --enable_runfiles --jobs=1 //oss_scripts/pip_package:build_pip_package -- "$(realpath .)"
-- 

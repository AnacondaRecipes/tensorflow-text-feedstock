From 720ab769cf17f0f4854fa010dc33715ad726221c Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Wed, 21 Jan 2026 06:56:52 -0800
Subject: [PATCH] unvendor only abseil

---
 oss_scripts/run_build.sh | 33 +++++++++++++++++++++++++++++++++
 1 file changed, 33 insertions(+)

diff --git a/oss_scripts/run_build.sh b/oss_scripts/run_build.sh
index 47f39b0..4e7a6ae 100755
--- a/oss_scripts/run_build.sh
+++ b/oss_scripts/run_build.sh
@@ -14,6 +14,39 @@ fi
 source oss_scripts/configure.sh
 
 # Add conda-specific configuration after configure
+# Configure Bazel to use conda-provided libabseil (20250127) instead of vendored abseil-cpp (20230802)
+if [[ -n "${PREFIX}" ]]; then
+  echo "" >> .bazelrc
+  echo "# Use conda-provided libabseil instead of vendored abseil-cpp" >> .bazelrc
+  # Add include path for abseil headers (using -I instead of -isystem to avoid affecting other packages)
+  # This makes abseil headers available but doesn't prioritize them over vendored dependencies
+  # The linker flags below will ensure we link against conda-provided abseil libraries
+  echo "build --copt=-I${PREFIX}/include" >> .bazelrc
+  echo "build --host_copt=-I${PREFIX}/include" >> .bazelrc
+  # Add library search path (only for linking, not for header resolution)
+  echo "build --linkopt=-L${PREFIX}/lib" >> .bazelrc
+  echo "build --host_linkopt=-L${PREFIX}/lib" >> .bazelrc
+  # Link against conda-provided abseil libraries (20250127)
+  echo "build --linkopt=-labsl_base" >> .bazelrc
+  echo "build --linkopt=-labsl_raw_logging_internal" >> .bazelrc
+  echo "build --linkopt=-labsl_strings" >> .bazelrc
+  echo "build --linkopt=-labsl_hash" >> .bazelrc
+  echo "build --linkopt=-labsl_city" >> .bazelrc
+  echo "build --linkopt=-labsl_low_level_hash" >> .bazelrc
+  echo "build --linkopt=-labsl_status" >> .bazelrc
+  echo "build --linkopt=-labsl_cord" >> .bazelrc
+  echo "build --linkopt=-labsl_time" >> .bazelrc
+  echo "build --linkopt=-labsl_synchronization" >> .bazelrc
+  echo "build --linkopt=-labsl_int128" >> .bazelrc
+  echo "build --linkopt=-labsl_log_severity" >> .bazelrc
+  echo "build --linkopt=-labsl_str_format_internal" >> .bazelrc
+  echo "build --linkopt=-labsl_graphcycles_internal" >> .bazelrc
+  echo "build --linkopt=-labsl_kernel_timeout_internal" >> .bazelrc
+  echo "build --linkopt=-labsl_malloc_internal" >> .bazelrc
+  # Ensure runtime library path includes conda lib directory (works for both Linux and macOS)
+  echo "build --linkopt=-Wl,-rpath,${PREFIX}/lib" >> .bazelrc
+fi
+
 if [[ $osname == "darwin" ]] && [[ -n "${SDKROOT}" ]]; then
   echo "" >> .bazelrc
   echo "# Conda macOS sysroot configuration" >> .bazelrc
-- 

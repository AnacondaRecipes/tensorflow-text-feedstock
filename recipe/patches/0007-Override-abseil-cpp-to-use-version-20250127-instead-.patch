+    
+    # absl/time/BUILD
+    repository_ctx.file("absl/time/BUILD", """
+package(default_visibility = ["//visibility:public"])
+
+cc_library(
+    name = "time",
+    hdrs = glob(["../../include/absl/time/**/*.h"]),

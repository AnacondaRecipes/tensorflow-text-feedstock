+    visibility = ["//visibility:public"],
+)
+""")
+    
+    # absl/functional/BUILD
+    repository_ctx.file("absl/functional/BUILD", """
+package(default_visibility = ["//visibility:public"])
+
+cc_library(
+    name = "any_invocable",
+    hdrs = ["../../include/absl/functional/any_invocable.h"],
+    includes = ["../../include"],
+    deps = ["//:base"],
+    visibility = ["//visibility:public"],
+)
+""")
+    
+    # absl/memory/BUILD
+    repository_ctx.file("absl/memory/BUILD", """
+package(default_visibility = ["//visibility:public"])
+
+cc_library(
+    name = "memory",
+    hdrs = glob(["../../include/absl/memory/**/*.h"]),
+    includes = ["../../include"],
+    deps = ["//:base"],
+    visibility = ["//visibility:public"],
+)
+""")
+    
+    # absl/status/BUILD
+    repository_ctx.file("absl/status/BUILD", """
+package(default_visibility = ["//visibility:public"])
+
+cc_library(
+    name = "status",
+    hdrs = glob(["../../include/absl/status/**/*.h"]),
+    includes = ["../../include"],
+    deps = ["//:base", "//absl/strings:strings", "//:raw_logging_internal"],
+    linkopts = ["-L../../lib", "-labsl_status"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "statusor",
+    hdrs = ["../../include/absl/status/statusor.h"],
+    includes = ["../../include"],
+    deps = [":status", "//absl/strings:strings", "//:utility"],
+    visibility = ["//visibility:public"],
+)
+""")
+    
+    # absl/strings/BUILD
+    repository_ctx.file("absl/strings/BUILD", """
+package(default_visibility = ["//visibility:public"])
+
+cc_library(
+    name = "strings",
+    hdrs = glob(["../../include/absl/strings/**/*.h"]),
+    includes = ["../../include"],
+    deps = ["//:base", "//absl/memory:memory", "//:raw_logging_internal", "//:meta"],
+    linkopts = ["-L../../lib", "-labsl_strings"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "cord",
+    hdrs = ["../../include/absl/strings/cord.h"],
+    includes = ["../../include"],
+    deps = [":strings", "//:base", "//:raw_logging_internal"],
+    linkopts = ["-L../../lib", "-labsl_cord"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "str_format",
+    hdrs = ["../../include/absl/strings/str_format.h"],
+    includes = ["../../include"],
+    deps = [":strings", "//:numeric"],
+    linkopts = ["-L../../lib", "-labsl_str_format_internal"],

From 4423b6bd5f4770d43589e14e1812f873e9c95e12 Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Wed, 21 Jan 2026 05:27:54 -0800
Subject: [PATCH] Override abseil-cpp to use version 20250127 instead of
 deprecated 20230802

---
 WORKSPACE                    |   7 +
 third_party/abseil/BUILD     |   4 +
 third_party/abseil/BUILD.bzl | 278 ++++++++++++++++++++++++++
 third_party/abseil/repo.bzl  | 366 +++++++++++++++++++++++++++++++++++
 4 files changed, 655 insertions(+)
 create mode 100644 third_party/abseil/BUILD
 create mode 100644 third_party/abseil/BUILD.bzl
 create mode 100644 third_party/abseil/repo.bzl

diff --git a/WORKSPACE b/WORKSPACE
index 5bc8329..e768354 100644
--- a/WORKSPACE
+++ b/WORKSPACE
@@ -1,6 +1,7 @@
 workspace(name = "org_tensorflow_text")
 
 load("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")
+load("//third_party/abseil:repo.bzl", "abseil_conda_repository")
 
 http_archive(
     name = "icu",
@@ -127,6 +128,12 @@ load("@pypi//:requirements.bzl", "install_deps")
 
 install_deps()
 
+# Override abseil-cpp to use conda-provided libabseil 20250127 instead of deprecated 20230802
+# Use system-installed abseil from conda package
+# Note: PREFIX environment variable must be set (done by conda-build)
+# We use a repository rule to expand PREFIX at repository load time
+abseil_conda_repository(name = "com_google_absl")
+
 # Initialize TensorFlow dependencies.
 load("@org_tensorflow//tensorflow:workspace3.bzl", "tf_workspace3")
 tf_workspace3()
diff --git a/third_party/abseil/BUILD b/third_party/abseil/BUILD
new file mode 100644
index 0000000..8a3182d
--- /dev/null
+++ b/third_party/abseil/BUILD

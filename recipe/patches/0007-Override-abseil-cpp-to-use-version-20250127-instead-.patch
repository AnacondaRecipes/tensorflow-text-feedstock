diff --git a/third_party/abseil/repo.bzl b/third_party/abseil/repo.bzl
new file mode 100644
index 0000000..11649a0
--- /dev/null
+++ b/third_party/abseil/repo.bzl
@@ -0,0 +1,366 @@
+"""Repository rule to use conda-provided abseil-cpp."""
+
+def _abseil_conda_repository_impl(repository_ctx):
+    """Implementation of abseil_conda_repository rule."""
+    # Get PREFIX from environment (set by conda-build)
+    prefix = repository_ctx.os.environ.get("PREFIX", "")
+    if not prefix:
+        fail("PREFIX environment variable not set. This rule requires conda-build environment.")
+    
+    # Create symlinks to the actual prefix so the paths resolve
+    repository_ctx.symlink(prefix + "/include", "include")
+    repository_ctx.symlink(prefix + "/lib", "lib")
+    
+    # Create BUILD file at root (for base targets)
+    repository_ctx.file("BUILD", """
+package(default_visibility = ["//visibility:public"])
+
+cc_library(
+    name = "base",
+    hdrs = glob(["include/absl/base/**/*.h"]),
+    includes = ["include"],
+    linkopts = ["-Llib", "-labsl_base"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "config",
+    hdrs = ["include/absl/base/config.h"],
+    includes = ["include"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "core_headers",
+    hdrs = ["include/absl/base/core_headers.h"],
+    includes = ["include"],
+    deps = [":config"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "base_internal",
+    hdrs = glob(["include/absl/base/internal/**/*.h"]),
+    includes = ["include"],
+    deps = [":config", ":core_headers"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "log_severity",
+    hdrs = ["include/absl/base/log_severity.h"],
+    includes = ["include"],
+    deps = [":base"],
+    linkopts = ["-Llib", "-labsl_log_severity"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "raw_logging_internal",
+    hdrs = ["include/absl/base/internal/raw_logging.h"],
+    includes = ["include"],
+    deps = [":base", ":log_severity"],
+    linkopts = ["-Llib", "-labsl_raw_logging_internal"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "atomic_hook",
+    hdrs = ["include/absl/base/internal/atomic_hook.h"],
+    includes = ["include"],
+    deps = [":base", ":config"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "meta",
+    hdrs = glob(["include/absl/meta/**/*.h"]),
+    includes = ["include"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "utility",
+    hdrs = glob(["include/absl/utility/**/*.h"]),
+    includes = ["include"],
+    deps = [":base", ":meta"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "numeric",
+    hdrs = glob(["include/absl/numeric/**/*.h"]),
+    includes = ["include"],
+    deps = [":int128"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "int128",
+    hdrs = ["include/absl/numeric/int128.h"],
+    includes = ["include"],
+    deps = [":base"],
+    linkopts = ["-Llib", "-labsl_int128"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "city",
+    hdrs = ["include/absl/hash/internal/city.h"],
+    includes = ["include"],
+    linkopts = ["-Llib", "-labsl_city"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "low_level_hash",
+    hdrs = ["include/absl/hash/internal/low_level_hash.h"],
+    includes = ["include"],
+    linkopts = ["-Llib", "-labsl_low_level_hash"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "hash",
+    hdrs = glob(["include/absl/hash/**/*.h"]),
+    includes = ["include"],
+    deps = [":base", ":city", ":low_level_hash"],
+    linkopts = ["-Llib", "-labsl_hash"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "malloc_internal",
+    hdrs = ["include/absl/base/internal/malloc_internal.h"],
+    includes = ["include"],
+    deps = [":base", ":base_internal", ":config", ":core_headers"],
+    linkopts = ["-Llib", "-labsl_malloc_internal"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "graphcycles_internal",
+    hdrs = ["include/absl/base/internal/graphcycles.h"],
+    includes = ["include"],
+    deps = [":base", ":malloc_internal"],
+    linkopts = ["-Llib", "-labsl_graphcycles_internal"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(

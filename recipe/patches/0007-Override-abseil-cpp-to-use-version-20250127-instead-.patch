+    # Create BUILD files in subdirectories for proper package structure
+    # absl/base/BUILD
+    repository_ctx.file("absl/base/BUILD", """
+package(default_visibility = ["//visibility:public"])
+
+alias(
+    name = "base",
+    actual = "//:base",
+    visibility = ["//visibility:public"],
+)
+""")
+    
+    # absl/meta/BUILD
+    repository_ctx.file("absl/meta/BUILD", """
+package(default_visibility = ["//visibility:public"])
+
+alias(
+    name = "meta",
+    actual = "//:meta",
+    visibility = ["//visibility:public"],
+)
+""")
+    
+    # absl/container/BUILD
+    repository_ctx.file("absl/container/BUILD", """
+package(default_visibility = ["//visibility:public"])
+
+cc_library(
+    name = "container",
+    hdrs = glob(["../../include/absl/container/**/*.h"]),
+    includes = ["../../include"],
+    deps = ["//:base"],
+    visibility = ["//visibility:public"],
+)
+
+cc_library(
+    name = "flat_hash_map",
+    hdrs = ["../../include/absl/container/flat_hash_map.h"],
+    includes = ["../../include"],
+    deps = [":container", "//:hash", "//:raw_hash_set"],

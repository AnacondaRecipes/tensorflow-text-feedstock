From 1a14bc9289a57c4e612434043af15a1815ae01e4 Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Mon, 19 Jan 2026 03:21:59 -0800
Subject: [PATCH] unvendor tensorflow dependency

---
 oss_scripts/run_build.sh | 6 +++---
 oss_scripts/run_tests.sh | 6 +++---
 2 files changed, 6 insertions(+), 6 deletions(-)

diff --git a/oss_scripts/run_build.sh b/oss_scripts/run_build.sh
index aae7b7d..8a75cc4 100755
--- a/oss_scripts/run_build.sh
+++ b/oss_scripts/run_build.sh
@@ -14,9 +14,9 @@ fi
 source oss_scripts/configure.sh
 
 # Set tensorflow version
-if [[ $osname != "darwin" ]] || [[ ! $(sysctl -n machdep.cpu.brand_string) =~ "Apple" ]]; then
-  source oss_scripts/prepare_tf_dep.sh
-fi
+#if [[ $osname != "darwin" ]] || [[ ! $(sysctl -n machdep.cpu.brand_string) =~ "Apple" ]]; then
+#  source oss_scripts/prepare_tf_dep.sh
+#fi
 
 # Build the pip package.
 # Execute only one action at a time instead of utilizing multiple parallel jobs
diff --git a/oss_scripts/run_tests.sh b/oss_scripts/run_tests.sh
index e9d476f..a1c36c3 100644
--- a/oss_scripts/run_tests.sh
+++ b/oss_scripts/run_tests.sh
@@ -16,8 +16,8 @@ set -e  # fail and exit on any command erroring
 #fi
 
 # Set tensorflow version
-if [[ $osname != "Darwin" ]] || [[ ! $(sysctl -n machdep.cpu.brand_string) =~ "Apple" ]]; then
-  source oss_scripts/prepare_tf_dep.sh
-fi
+#if [[ $osname != "Darwin" ]] || [[ ! $(sysctl -n machdep.cpu.brand_string) =~ "Apple" ]]; then
+#  source oss_scripts/prepare_tf_dep.sh
+#fi
 
 bazel test --test_output=errors --keep_going --jobs=1 tensorflow_text:all

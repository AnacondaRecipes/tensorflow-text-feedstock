From 4124be500642a6bf4629144834aa64d30ae7951d Mon Sep 17 00:00:00 2001
From: Steven <scrass@anaconda.com>
Date: Wed, 23 Jul 2025 17:26:23 -0600
Subject: [PATCH] Apply 0002-make-other-minor-adjustments changes

- Add --jobs=1 to bazel run command in run_build.sh to limit parallelism
- Comment out plat_name in build_pip_package.sh bdist_wheel command
- run_tests.sh already has --jobs=1 applied upstream
---
 oss_scripts/pip_package/build_pip_package.sh | 2 +-
 oss_scripts/run_build.sh                     | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/oss_scripts/pip_package/build_pip_package.sh b/oss_scripts/pip_package/build_pip_package.sh
index 8e411ef..292ee51 100755
--- a/oss_scripts/pip_package/build_pip_package.sh
+++ b/oss_scripts/pip_package/build_pip_package.sh
@@ -101,7 +101,7 @@ main() {
   if is_nightly; then
     $installed_python setup.nightly.py bdist_wheel --universal $plat_name
   else
-    $installed_python setup.py bdist_wheel --universal $plat_name
+    $installed_python setup.py bdist_wheel --universal #$plat_name
   fi
   cp dist/*.whl "${output_dir}"
 }
diff --git a/oss_scripts/run_build.sh b/oss_scripts/run_build.sh
index 029af0b..18359f1 100755
--- a/oss_scripts/run_build.sh
+++ b/oss_scripts/run_build.sh
@@ -19,7 +19,7 @@ if [[ $osname != "darwin" ]] || [[ ! $(sysctl -n machdep.cpu.brand_string) =~ "A
 fi
 
 # Build the pip package.
-bazel run ${BUILD_ARGS[@]} --enable_runfiles //oss_scripts/pip_package:build_pip_package -- "$(realpath .)"
+bazel run ${BUILD_ARGS[@]} --enable_runfiles --jobs=1 //oss_scripts/pip_package:build_pip_package -- "$(realpath .)"
 
 if [ -n "${AUDITWHEEL_PLATFORM}" ]; then
   echo $(date) : "=== Auditing wheel"
-- 

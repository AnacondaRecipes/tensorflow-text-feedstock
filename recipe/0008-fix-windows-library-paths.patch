From 6e4a8c5f7e4e8b4d2c3a1b0f9e8d7c6b5a4f3e2d Mon Sep 17 00:00:00 2001
From: Assistant <assistant@anaconda.com>
Date: Wed, 23 Oct 2024 16:00:00 -0600
Subject: [PATCH] Fix Windows library paths for tensorflow_framework

Make library copying conditional on platform to avoid looking for Linux .so files on Windows

---
 tensorflow_text/BUILD | 8 +++++---
 1 file changed, 5 insertions(+), 3 deletions(-)

diff --git a/tensorflow_text/BUILD b/tensorflow_text/BUILD
index 1234567..abcdefg 100644
--- a/tensorflow_text/BUILD
+++ b/tensorflow_text/BUILD
@@ -182,9 +182,11 @@ pybind_extension(
         "//tensorflow_text/core/kernels:regex_split_kernels",
         "//tensorflow_text/core/kernels:wordpiece_kernel",
     ],
-    tags = ["no-pip"] + tf_custom_op_py_library_deps([
-        "@pypi_tensorflow//:site-packages/tensorflow/libtensorflow_framework.so.2",
-    ]),
+    tags = ["no-pip"] + select({
+        "@org_tensorflow//tensorflow:windows": [],
+        "//conditions:default": tf_custom_op_py_library_deps([
+            "@pypi_tensorflow//:site-packages/tensorflow/libtensorflow_framework.so.2",
+        ]),
+    }),
 )

 py_library(
